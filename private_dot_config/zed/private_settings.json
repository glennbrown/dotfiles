// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "auto_install_extensions": {
    "ansible": true,
    "asciidoc": true,
    "bearded-icons": true,
    "csharp": true,
    "csv": true,
    "d2": true,
    "docker-compose": true,
    "dockerfile": true,
    "elixir": true,
    "erlang": true,
    "git-firefly": true,
    "helm": true,
    "html": true,
    "html-jinja": true,
    "ini": true,
    "java": true,
    "jinja2": true,
    "just": true,
    "latex": true,
    "log": true,
    "lua": true,
    "make": true,
    "php": true,
    "plantuml": true,
    "powershell": true,
    "proto": true,
    "rainbow-csv": true,
    "ruby": true,
    "sql": true,
    "swift": true,
    "ssh-config": true,
    "terraform": true,
    "template": true,
    "toml": true,
    "xcode-themes": true,
    "xml": true,
    "zig": true,
  },
  "proxy": "",
  "inlay_hints": {
    "enabled": true,
  },
  "tab_size": 2,
  "project_panel": {
    "git_status_indicator": true,
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "edit_predictions": {
    "mode": "subtle",
  },
  "show_edit_predictions": true,
  "disable_ai": false,
  "buffer_line_height": "standard",
  "terminal": {
    "copy_on_select": true,
    "option_as_meta": true,
    "show_count_badge": true,
    "font_family": "JetBrainsMono Nerd Font Mono",
    "font_size": 14.0,
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "Liga SFMono Nerd Font",
  "icon_theme": "Bearded Icons",
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "Xcode Default Light",
    "dark": "Xcode Default Dark",
  },
}
